    "settings.permissions.footer": {
      "comment": "Footer text explaining the benefit of direct paste from the overlay and the need for Accessibility permission. Audited call site(s): Clipmighty/Features/Settings/GeneralSettingsView.swift:138.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Allows Clipmighty to insert selected items directly into the active window. This reduces the need for repetitive manual keystrokes and complex key chords."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Memungkinkan Clipmighty menyisipkan item yang dipilih langsung ke jendela aktif. Ini mengurangi kebutuhan penekanan tombol manual berulang dan kombinasi tombol yang rumit."
          }
        },
        "fr-CA": {
          "stringUnit": {
            "state": "translated",
            "value": "Permet à Clipmighty d’insérer les éléments sélectionnés directement dans la fenêtre active. Cela réduit les frappes manuelles répétitives et les combinaisons de touches complexes."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Permet à Clipmighty d’insérer les éléments sélectionnés directement dans la fenêtre active. Vous avez ainsi moins de frappes manuelles répétitives et de raccourcis complexes à effectuer."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ermöglicht Clipmighty, ausgewählte Elemente direkt in das aktive Fenster einzusetzen. Dies reduziert die Notwendigkeit für wiederholte manuelle Tastatureingaben und komplexe Tastenkombinationen."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Stelt Clipmighty in staat om geselecteerde onderdelen direct in het actieve venster in te voegen. Dit vermindert de noodzaak voor herhaalde handmatige toetsaanslagen en complexe toetscombinaties."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "允许 Clipmighty 直接将选定的项目粘贴到活动窗口中。这将减少重复的手动按键以及复杂的快捷键操作。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Clipmightyが選択した項目をアクティブなウィンドウに直接ペーストできるようにします。これにより、反復的な手動のキー入力や複雑なショートカットの必要性が減ります。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Позволяет Clipmighty вставлять выбранные элементы непосредственно в активное окно. Это снижает потребность в повторяющихся ручных нажатиях клавиш и сложных сочетаниях."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يسمح لـ Clipmighty بإدراج العناصر المحددة مباشرة في النافذة النشطة. يقلل هذا من الحاجة إلى ضغطات المفاتيح اليدوية المتكررة واختصارات لوحة المفاتيح المعقدة."
          }
        }
      }
    },
