    "onboarding.tutorial.menuBar.description": {
      "comment": "Onboarding hint explaining how to open Clipmighty from the menu bar or with the default shortcut. Audited call site(s): Clipmighty/Features/Onboarding/TutorialStepView.swift:73.",
      "extractionState": "manual",
      "localizations": {
