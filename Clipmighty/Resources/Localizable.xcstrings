    "settings.sync.restart.message": {
      "comment": "Alert message explaining that Clipmighty must restart before sync setting changes take effect. Audited call site(s): Clipmighty/Features/Settings/SyncSettingsView.swift:27.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Clipmighty needs to restart to apply changes to sync settings."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Clipmighty perlu dimulai ulang untuk menerapkan perubahan pengaturan sinkronisasi."
          }
        },
        "fr-CA": {
          "stringUnit": {
            "state": "translated",
            "value": "Clipmighty doit redémarrer pour appliquer les modifications aux réglages de synchronisation."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Clipmighty doit redémarrer pour appliquer les modifications des réglages de synchronisation."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Clipmighty muss neu gestartet werden, um Änderungen an den Synchronisierungseinstellungen anzuwenden."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Clipmighty moet opnieuw worden opgestart om wijzigingen in de synchronisatie-instellingen toe te passen."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "需要重启 Clipmighty 才能应用同步设置的更改。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "同期設定の変更を適用するには、Clipmightyを再起動する必要があります。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Clipmighty необходимо перезапустить, чтобы применить изменения в настройках синхронизации."
          }
        },
        "ar": {
