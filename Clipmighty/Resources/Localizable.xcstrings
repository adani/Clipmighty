    "quit.alert.message": {
      "comment": "Quit confirmation message explaining that clipboard monitoring stops after quitting. Audited call site(s): Clipmighty/App/AppDelegate.swift:88.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Are you sure you want to quit the application? It will stop monitoring your clipboard."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Anda yakin ingin menutup aplikasi? Clipmighty akan berhenti memantau clipboard Anda."
          }
        },
        "fr-CA": {
          "stringUnit": {
            "state": "translated",
            "value": "Voulez-vous vraiment quitter l’application? Elle cessera de surveiller votre presse-papiers."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Voulez-vous vraiment quitter l’application ? La surveillance du presse-papiers sera arrêtée."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Möchten Sie die Anwendung wirklich beenden? Die Überwachung Ihrer Zwischenablage wird dadurch gestoppt."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Weet je zeker dat je de app wilt stoppen? Het monitoren van je klembord wordt hiermee gestopt."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "您确定要退出吗？这将停止对您的剪贴板进行监控。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "本当に終了しますか？クリップボードの監視が停止します。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Вы уверены, что хотите завершить работу приложения? Это остановит мониторинг Вашего буфера обмена."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "هل أنت متأكد أنك تريد إنهاء التطبيق؟ سيتم إيقاف مراقبة حافظتك."
          }
        }
      }
    },
