    "manualBundleID.notFound.description": {
      "comment": "Helper text reassuring the user that a bundle ID can still be excluded even if the app is not installed now. Audited call site(s): Clipmighty/Features/Settings/ManualBundleIDSheet.swift:81.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You can still add this bundle ID, but the app may not be installed."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Anda tetap dapat menambahkan bundle ID ini, tetapi aplikasinya mungkin belum terinstal."
          }
        },
        "fr-CA": {
          "stringUnit": {
            "state": "translated",
            "value": "Vous pouvez quand même ajouter cet identifiant de bundle, mais l’app n’est peut-être pas installée."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vous pouvez toujours ajouter cet identifiant de bundle, mais l’application n’est peut-être pas installée."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sie können diese Bundle-ID weiterhin hinzufügen, aber die App ist möglicherweise nicht installiert."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Je kunt deze bundel-ID nog steeds toevoegen, maar de app is mogelijk niet geïnstalleerd."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "您仍可以添加此包标识符，但该应用可能未安装。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このバンドルIDを追加することは可能ですが、アプリケーションがインストールされていない可能性があります。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Вы все еще можете добавить этот идентификатор пакета, но приложение может быть не установлено."
