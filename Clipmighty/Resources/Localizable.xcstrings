    "onboarding.tutorial.description": {
      "comment": "Onboarding tutorial body text instructing the user to copy sample text and paste it with the shortcut. Audited call site(s): Clipmighty/Features/Onboarding/TutorialStepView.swift:39.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Let's try out Clipmighty! Copy one of the texts below, then paste it using the shortcut."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Mari coba Clipmighty! Salin salah satu teks di bawah, lalu tempel menggunakan pintasan."
          }
        },
        "fr-CA": {
          "stringUnit": {
            "state": "translated",
            "value": "Essayons Clipmighty! Copiez l’un des textes ci-dessous, puis collez-le avec le raccourci."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Essayons Clipmighty ! Copiez l’un des textes ci-dessous, puis collez-le à l’aide du raccourci."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Lassen Sie uns Clipmighty ausprobieren! Kopieren Sie einen der folgenden Texte und setzen Sie ihn mit der Tastenkombination ein."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Laten we Clipmighty uitproberen! Kopieer een van de onderstaande teksten en plak deze met de toetscombinatie."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "让我们来试试 Clipmighty 吧！复制以下任意一段文本，然后使用快捷键粘贴。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Clipmightyを試してみましょう！以下のテキストのいずれかをコピーし、ショートカットを使ってペーストしてください。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Давайте проверим Clipmighty! Скопируйте один из текстов ниже, а затем вставьте его с помощью сочетания клавиш."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "دعنا نجرب Clipmighty! انسخ أحد النصوص أدناه، ثم الصقه باستخدام الاختصار."
          }
        }
      }
    },
