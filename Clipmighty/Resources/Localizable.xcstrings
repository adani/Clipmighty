    "settings.shortcut.footer": {
      "comment": "Footer text in Keyboard Shortcut settings explaining shortcuts and the requirement for a modifier key. Audited call site(s): Clipmighty/Features/Settings/GeneralSettingsView.swift:99.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Set shortcuts for opening the paste overlay and pinning items in it. The shortcut must include at least one modifier key (⌘, ⇧, ⌥, or ⌃)."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Atur pintasan untuk membuka overlay tempel dan menyematkan item di dalamnya. Pintasan harus menyertakan setidaknya satu tombol pengubah (⌘, ⇧, ⌥, atau ⌃)."
          }
        },
        "fr-CA": {
          "stringUnit": {
            "state": "translated",
            "value": "Définissez des raccourcis pour ouvrir le panneau de collage et y épingler des éléments. Le raccourci doit inclure au moins une touche de modification (⌘, ⇧, ⌥ ou ⌃)."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Définissez les raccourcis pour ouvrir le panneau de collage et y épingler des éléments. Le raccourci doit inclure au moins une touche de modification (⌘, ⇧, ⌥ ou ⌃)."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Legen Sie Tastenkombinationen fest, um das Einsetzen-Overlay zu öffnen und Elemente darin anzupinnen. Die Tastenkombination muss mindestens eine Modifikatortaste (⌘, ⇧, ⌥ oder ⌃) enthalten."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Stel toetscombinaties in voor het openen van de plak-overlay en het vastzetten van onderdelen daarin. De toetscombinatie moet ten minste één modificatietoets (⌘, ⇧, ⌥ of ⌃) bevatten."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "设置快捷键以打开粘贴悬浮窗以及在悬浮窗内固定项目。快捷键必须至少包含一个修饰键（⌘、⇧、⌥ 或 ⌃）。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ペーストオーバーレイを開き、アイテムを固定するためのキーボードショートカットを設定します。ショートカットには少なくとも1つの修飾キー（⌘、⇧、⌥、または ⌃）が含まれている必要があります。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Установите сочетания клавиш для открытия панели вставки и закрепления в ней элементов. Сочетание должно включать хотя бы одну клавишу-модификатор (⌘, ⇧, ⌥ или ⌃)."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "قم بتعيين اختصارات لفتح نافذة اللصق وتثبيت العناصر فيها. يجب أن يتضمن الاختصار مفتاح تعديل واحد على الأقل (⌘ أو ⇧ أو ⌥ أو ⌃)."
          }
        }
      }
    },
