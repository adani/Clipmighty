    "onboarding.permissions.privacyFirst.description": {
      "comment": "Onboarding body text explaining Accessibility permission is used only for paste simulation and app identification, not data transmission. Audited call site(s): Clipmighty/Features/Onboarding/PermissionsStepView.swift:85.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This permission is strictly used to simulate the 'Paste' command and identify source apps. Your clipboard history remains local and is never transmitted."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Izin ini hanya digunakan untuk mensimulasikan perintah 'Tempel' dan mengidentifikasi aplikasi sumber. Riwayat clipboard Anda tetap tersimpan lokal dan tidak pernah dikirim."
          }
        },
        "fr-CA": {
          "stringUnit": {
            "state": "translated",
            "value": "Cette autorisation sert uniquement à simuler la commande Coller et à identifier les apps sources. L’historique de votre presse-papiers reste local et n’est jamais transmis."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cette autorisation sert strictement à simuler la commande « Coller » et à identifier les applications sources. Votre historique du presse-papiers reste local et n’est jamais transmis."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Diese Berechtigung wird ausschließlich verwendet, um den Befehl „Einsetzen“ zu simulieren und Quell-Apps zu identifizieren. Ihr Zwischenablage-Verlauf bleibt lokal und wird niemals übertragen."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Deze bevoegdheid wordt uitsluitend gebruikt om de 'Plak'-opdracht te simuleren en bron-apps te identificeren. Je klembordgeschiedenis blijft lokaal en wordt nooit verzonden."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "此权限仅用于模拟“粘贴”命令及识别来源应用。您的剪贴板历史记录始终保存在本地，绝不会被传输。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "この権限は「ペースト」コマンドのシミュレートとソースアプリの特定にのみ使用されます。クリップボードの履歴はローカルに保持され、送信されることはありません。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Это разрешение используется исключительно для имитации команды «Вставить» и определения исходных приложений. История Вашего буфера обмена остается локальной и никогда не передается."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يُستخدم هذا الإذن حصرياً لمحاكاة أمر \"لصق\" وتحديد التطبيقات المصدر. يظل سجل الحافظة الخاص بك محلياً ولا يتم إرساله أبداً."
          }
        }
      }
    },
