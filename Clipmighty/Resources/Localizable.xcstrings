    "settings.rules.excludedApps.footer": {
      "comment": "Footer text explaining the two ways to add excluded apps: browsing installed apps or entering a bundle ID. Audited call site(s): Clipmighty/Features/Settings/RulesSettingsView.swift:189.",
      "extractionState": "manual",
      "localizations": {
        "en": {
