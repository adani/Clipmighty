    "onboarding.tutorial.menuBar.title": {
      "comment": "Onboarding tutorial subheading that points users to the Clipmighty menu bar icon. Audited call site(s): Clipmighty/Features/Onboarding/TutorialStepView.swift:70.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Find Clipmighty in your menu bar"
          }
        },
