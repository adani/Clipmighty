    "settings.history.clear.message": {
      "comment": "Destructive confirmation message warning that all clipboard history will be permanently deleted. Audited call site(s): Clipmighty/Features/Settings/RulesSettingsView.swift:259.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This will permanently delete all clipboard history. This action cannot be undone."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Tindakan ini akan menghapus seluruh riwayat clipboard secara permanen. Tindakan ini tidak dapat diurungkan."
          }
        },
        "fr-CA": {
          "stringUnit": {
            "state": "translated",
            "value": "Tout l’historique du presse-papiers sera supprimé définitivement. Cette action est irréversible."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tout l’historique du presse-papiers sera définitivement supprimé. Cette action est irréversible."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dadurch wird der gesamte Zwischenablage-Verlauf dauerhaft gelöscht. Diese Aktion kann nicht rückgängig gemacht werden."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Hiermee wordt de volledige klembordgeschiedenis permanent verwijderd. Deze actie kan niet ongedaan worden gemaakt."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "这将永久删除所有剪贴板历史记录。此操作无法撤销。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "これにより、クリップボードの履歴がすべて完全に削除されます。この操作は取り消せません。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Это навсегда удалит всю историю буфера обмена. Это действие нельзя отменить."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "سيؤدي هذا إلى حذف سجل الحافظة بالكامل نهائياً. لا يمكن التراجع عن هذا الإجراء."
          }
        }
      }
    },
