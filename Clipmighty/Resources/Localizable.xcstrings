      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "To automatically insert history items directly into your active apps, Clipmighty needs Accessibility permission. This allows our overlay to simulate the \"Paste\" command for you, saving you manual effort."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Untuk menyisipkan item riwayat secara otomatis langsung ke aplikasi aktif Anda, Clipmighty memerlukan izin Aksesibilitas. Izin ini memungkinkan overlay kami mensimulasikan perintah \"Tempel\" untuk Anda, sehingga Anda tidak perlu melakukannya secara manual."
          }
        },
        "fr-CA": {
          "stringUnit": {
            "state": "translated",
            "value": "Pour insérer automatiquement des éléments de l’historique directement dans vos apps actives, Clipmighty a besoin de l’autorisation Accessibilité. Celle-ci permet au panneau de simuler la commande Coller pour vous éviter des étapes manuelles."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Pour insérer automatiquement les éléments de l’historique directement dans vos applications actives, Clipmighty a besoin de l’autorisation Accessibilité. Cela permet à notre panneau de simuler la commande « Coller » pour vous éviter des manipulations manuelles."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Damit Clipmighty Elemente aus dem Verlauf automatisch in Ihre aktiven Apps einfügen kann, wird die Bedienungshilfen-Berechtigung benötigt. Dadurch kann unser Overlay den „Einsetzen“-Befehl für Sie simulieren und Ihnen manuelle Arbeit ersparen."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Om automatisch onderdelen uit de geschiedenis direct in je actieve apps in te voegen, heeft Clipmighty de bevoegdheid voor Toegankelijkheid nodig. Hiermee kan onze overlay de 'Plak'-opdracht voor je simuleren, wat je handmatig werk bespaart."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "为了让 Clipmighty 自动将历史记录中的项目粘贴到活动应用中，需要辅助功能权限。这允许我们的悬浮窗为您模拟“粘贴”命令，省去您的手动操作。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "履歴からアクティブなアプリに自動的にペーストするため、Clipmightyはアクセシビリティの権限を必要とします。これにより、オーバーレイが「ペースト」コマンドをシミュレートし、手動での作業を省くことができます。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Для автоматической вставки элементов истории прямо в Ваши активные приложения Clipmighty требуется разрешение на Универсальный доступ. Это позволяет нашей панели имитировать команду «Вставить» за Вас, избавляя от ручных действий."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لإدراج عناصر السجل تلقائياً في تطبيقاتك النشطة، يحتاج Clipmighty إلى إذن الوصول. يسمح هذا للبرنامج بمحاكاة أمر \"لصق\" نيابةً عنك، مما يوفر عليك الجهد اليدوي."
          }
        }
      }
    },
