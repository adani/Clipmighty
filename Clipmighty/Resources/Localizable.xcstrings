    "settings.sync.icloud.disabledDescription": {
      "comment": "Description under the iCloud sync toggle when sync is off, inviting the user to enable cross-device history sync. Audited call site(s): Clipmighty/Features/Settings/SyncSettingsView.swift:45.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Enable to sync clipboard history across your devices."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Aktifkan untuk menyinkronkan riwayat clipboard di semua perangkat Anda."
          }
        },
        "fr-CA": {
          "stringUnit": {
            "state": "translated",
            "value": "Activez cette option pour synchroniser l’historique du presse-papiers sur vos appareils."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Activez cette option pour synchroniser l’historique du presse-papiers entre vos appareils."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Aktivieren Sie dies, um den Zwischenablage-Verlauf über Ihre Geräte hinweg zu synchronisieren."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Schakel in om je klembordgeschiedenis te synchroniseren tussen je apparaten."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "启用此选项即可在您的所有设备之间同步剪贴板历史记录。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "デバイス間でクリップボードの履歴を同期するには、これを有効にします。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Включите, чтобы синхронизировать историю буфера обмена между Вашими устройствами."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "قم بالتمكين لمزامنة سجل الحافظة عبر أجهزتك."
          }
        }
      }
    },
    "settings.sync.icloud.enabledDescription": {
      "comment": "Description under the iCloud sync toggle when sync is on, explaining history syncs across devices on the same iCloud account. Audited call site(s): Clipmighty/Features/Settings/SyncSettingsView.swift:39.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Clipboard history syncs across your devices signed into the same iCloud account."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Riwayat clipboard disinkronkan di semua perangkat yang masuk ke akun iCloud yang sama."
          }
        },
        "fr-CA": {
          "stringUnit": {
            "state": "translated",
            "value": "L’historique du presse-papiers se synchronise sur vos appareils connectés au même compte iCloud."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L’historique du presse-papiers se synchronise entre vos appareils connectés au même compte iCloud."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der Zwischenablage-Verlauf wird auf Ihren Geräten synchronisiert, die mit demselben iCloud-Account angemeldet sind."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Je klembordgeschiedenis wordt gesynchroniseerd tussen je apparaten die zijn ingelogd met hetzelfde iCloud-account."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "您的剪贴板历史记录将在使用同一 iCloud 账户登录的设备间同步。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "クリップボードの履歴は、同じiCloudアカウントでサインインしているデバイス間で同期されます。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "История буфера обмена синхронизируется между Вашими устройствами, вошедшими в одну и ту же учетную запись iCloud."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تتم مزامنة سجل الحافظة عبر أجهزتك المسجلة بنفس حساب iCloud."
          }
        }
      }
    },
