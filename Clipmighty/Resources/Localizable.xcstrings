    "settings.rules.privacy.footer": {
      "comment": "Footer text noting that password-manager detection depends on standard markers and browser extensions may not provide them. Audited call site(s): Clipmighty/Features/Settings/RulesSettingsView.swift:97.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This feature relies on standard markers that most password managers use. Browser extensions may not always apply these markers."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Fitur ini bergantung pada penanda standar yang digunakan sebagian besar pengelola kata sandi. Ekstensi browser mungkin tidak selalu menerapkan penanda ini."
          }
        },
        "fr-CA": {
          "stringUnit": {
            "state": "translated",
            "value": "Cette fonctionnalité repose sur des indicateurs standard utilisés par la plupart des gestionnaires de mots de passe. Les extensions de navigateur ne les appliquent pas toujours."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cette fonctionnalité s’appuie sur les marqueurs standard utilisés par la plupart des gestionnaires de mots de passe. Les extensions de navigateur ne les appliquent pas toujours."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Diese Funktion stützt sich auf Standardmarkierungen, die die meisten Passwort-Manager verwenden. Browser-Erweiterungen wenden diese Markierungen möglicherweise nicht immer an."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Deze functie is afhankelijk van standaardmarkeringen die de meeste wachtwoordbeheerders gebruiken. Browzerextensies passen deze markeringen mogelijk niet altijd toe."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "此功能基于多数密码管理器使用的标准标记。浏览器扩展程序可能不总是应用这些标记。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "この機能は、多くのパスワードマネージャーが使用する標準のフラグに依存しています。ブラウザの拡張機能はこれらのフラグを常に適用するとは限りません。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Эта функция основана на стандартных маркерах, которые используют большинство менеджеров паролей. Расширения браузеров не всегда применяют эти маркеры."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تعتمد هذه الميزة على العلامات القياسية التي تستخدمها معظم برامج إدارة كلمات المرور. قد لا تطبق إضافات المتصفح هذه العلامات دائماً."
          }
        }
      }
    },
