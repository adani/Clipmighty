    "onboarding.excludedApps.description": {
      "comment": "Onboarding body text explaining that clipboard content from excluded apps is not stored, with password managers as an example. Audited call site(s): Clipmighty/Features/Onboarding/ExcludedAppsStepView.swift:34.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Clipboard content from these apps won't be saved. Great for password managers and sensitive apps."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Konten clipboard dari aplikasi ini tidak akan disimpan. Cocok untuk pengelola kata sandi dan aplikasi sensitif."
          }
        },
        "fr-CA": {
          "stringUnit": {
            "state": "translated",
            "value": "Le contenu du presse-papiers provenant de ces apps ne sera pas enregistré. Idéal pour les gestionnaires de mots de passe et les apps sensibles."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le contenu du presse-papiers provenant de ces applications ne sera pas enregistré. Idéal pour les gestionnaires de mots de passe et les applications sensibles."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Inhalte aus der Zwischenablage dieser Apps werden nicht gespeichert. Ideal für Passwort-Manager und sensible Apps."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Klembordmateriaal van deze apps wordt niet bewaard. Ideaal voor wachtwoordbeheerders en gevoelige apps."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "这些应用的剪贴板内容将不会被保存。非常适合密码管理器和涉及隐私的应用。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "これらのアプリからコピーされた内容は保存されません。パスワードマネージャーや機密情報を扱うアプリに最適です。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Содержимое буфера обмена из этих приложений не будет сохраняться. Идеально для менеджеров паролей и конфиденциальных приложений."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لن يتم حفظ محتوى الحافظة من هذه التطبيقات. تعتبر هذه الميزة مثالية لمديري كلمات المرور والتطبيقات الحساسة."
          }
        }
      }
    },
